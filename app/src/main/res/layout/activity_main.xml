<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/calc_fond">

    <!-- affichage -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingBottom="16dp">

        <!-- Ligne du calcul en cours ex: "125 × 3" -->
        <TextView
            android:id="@+id/textOperation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:gravity="end"
            android:text="125 × 3"
            android:textColor="@color/calc_display_operation"
            android:textSize="22sp" />

        <!-- Résultat principal — grand et blanc -->
        <TextView
            android:id="@+id/textResultat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:includeFontPadding="false"
            android:text="375"
            android:textColor="@color/calc_texte_blanc"
            android:textSize="72sp"
            android:textStyle="normal" />

    </LinearLayout>

    <!-- boutons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp">

        <!-- ligne 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAC"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_utilitaire"
                android:text="AC"
                android:textColor="@color/calc_texte_sombre"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlusMoins"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_utilitaire"
                android:text="+/-"
                android:textColor="@color/calc_texte_sombre"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPourcent"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_utilitaire"
                android:text="%"
                android:textColor="@color/calc_texte_sombre"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDiviser"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_operateur"
                android:text="÷"
                android:textColor="@color/calc_texte_blanc"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

        </LinearLayout>

        <!-- ligne 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn7"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_chiffre"
                android:text="7"
                android:textColor="@color/calc_texte_blanc"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn8"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_chiffre"
                android:text="8"
                android:textColor="@color/calc_texte_blanc"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn9"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_chiffre"
                android:text="9"
                android:textColor="@color/calc_texte_blanc"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMultiplier"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_operateur"
                android:gravity="center_horizontal|center_vertical"
                android:text="×"
                android:textColor="@color/calc_texte_blanc"
                android:textSize="34sp"
                android:textStyle="normal"
                app:cornerRadius="50dp" />

        </LinearLayout>

        <!-- ligne 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn4"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_chiffre"
                android:text="4"
                android:textColor="@color/calc_texte_blanc"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn5"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_chiffre"
                android:text="5"
                android:textColor="@color/calc_texte_blanc"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn6"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_chiffre"
                android:text="6"
                android:textColor="@color/calc_texte_blanc"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSoustraire"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_operateur"
                android:text="−"
                android:textColor="@color/calc_texte_blanc"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

        </LinearLayout>

        <!-- ligne 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn1"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_chiffre"
                android:text="1"
                android:textColor="@color/calc_texte_blanc"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn2"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_chiffre"
                android:text="2"
                android:textColor="@color/calc_texte_blanc"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn3"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_chiffre"
                android:text="3"
                android:textColor="@color/calc_texte_blanc"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdditionner"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_operateur"
                android:text="+"
                android:textColor="@color/calc_texte_blanc"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

        </LinearLayout>

        <!-- ligne 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- Bouton 0 — 2× plus large que les autres -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn0"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:layout_weight="2"
                android:backgroundTint="@color/calc_btn_chiffre"
                android:gravity="center_vertical|start"
                android:paddingStart="28dp"
                android:text="0"
                android:textColor="@color/calc_texte_blanc"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVirgule"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_chiffre"
                android:text=","
                android:textColor="@color/calc_texte_blanc"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEgal"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:backgroundTint="@color/calc_btn_egal"
                android:text="="
                android:textColor="@color/calc_texte_blanc"
                android:textSize="34sp"
                app:cornerRadius="50dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
